# Copy this file to `.env` (gitignored) and fill in the values.
# These connect the bronze loader AND dbt to the Azure SQL warehouse.
# Get the password (kept only in Terraform state) with:
#   cd infra; terraform output -raw sql_admin_password
MARKETLAKE_SQL_SERVER=sql-marketlake-dev-XXXX.database.windows.net
MARKETLAKE_SQL_DATABASE=marketlake
MARKETLAKE_SQL_USER=marketlakeadmin
MARKETLAKE_SQL_PASSWORD=
